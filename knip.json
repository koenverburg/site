{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "app/**/*.{ts,tsx}",
    "velite.config.js",
    "eslint.config.js"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}"
  ],
  "ignoreDependencies": [
    "@tailwindcss/postcss",
    "@typescript-eslint/eslint-plugin",
    "@typescript-eslint/parser"
  ],
  "ignoreBinaries": ["eslint"],
  "ignoreUnresolved": ["\\.velite"]
}
